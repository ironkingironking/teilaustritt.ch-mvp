    @media (prefers-color-scheme: light){:root{--bg:#f7fafc;--bg-alt:#ffffff;--text:#0f172a;--muted:#334155;--card:#ffffff;--border:#e2e8f0;--shadow:0 10px 30px rgba(2,8,23,.08)}}
    body{background:var(--bg);color:var(--text);font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Cantarell,Noto Sans,'Helvetica Neue',Arial}
    a{color:var(--primary);text-decoration:none}a:hover{text-decoration:underline}
    .container{max-width:var(--maxw);margin-inline:auto;padding:0 20px}
    header{position:sticky;top:0;z-index:50;background:color-mix(in srgb, var(--bg-alt) 85%, transparent);backdrop-filter:saturate(180%) blur(16px);border-bottom:1px solid var(--border)}
    .nav{display:flex;align-items:center;gap:22px;justify-content:space-between;height:64px}
    .brand{display:flex;align-items:center;gap:10px;font-weight:700}
    .brand-logo{width:28px;height:28px}
    nav ul{display:flex;gap:18px;list-style:none;margin:0;padding:0}
    nav a{padding:8px 10px;border-radius:10px}
    nav a.active, nav a:focus-visible{background:color-mix(in srgb, var(--primary) 16%, transparent);outline:none}
    .btn{display:inline-flex;align-items:center;gap:10px;border:1px solid var(--border);background:var(--primary);color:#fff;padding:12px 16px;border-radius:14px;font-weight:600;box-shadow:var(--shadow)}
    .btn.secondary{background:transparent;color:var(--text)}
    .btn.ghost{background:transparent;border-color:var(--primary);color:var(--primary)}
    .btn:where(:hover,:focus-visible){filter:brightness(1.05)}
    .hero{position:relative;overflow:hidden;padding:72px 0 44px;background:radial-gradient(1200px 600px at 10% -10%, color-mix(in srgb, var(--primary) 20%, transparent), transparent),radial-gradient(1000px 500px at 90% 0%, color-mix(in srgb, var(--accent) 15%, transparent), transparent)}
    .hero h1{font-size:clamp(28px,4vw,46px);line-height:1.15;margin:0 0 12px}
    .hero p{max-width:780px;margin:0 0 22px;color:var(--muted)}
    .cta-row{display:flex;gap:12px;flex-wrap:wrap}
    .pill{display:inline-flex;gap:8px;align-items:center;border:1px solid var(--border);background:var(--card);padding:8px 12px;border-radius:999px;color:var(--muted);font-size:14px;margin-bottom:10px}
    section{padding:48px 0;border-top:1px solid var(--border)}
    h2{font-size:clamp(22px,3.2vw,34px);margin:.2em 0 .6em}
    h3{font-size:clamp(18px,2.4vw,24px);margin:1em 0 .4em}
    p.lead{color:var(--muted);max-width:80ch}
    .grid{display:grid;gap:16px}
    .grid.cols-3{grid-template-columns:repeat(1,minmax(0,1fr))}
    @media(min-width:780px){.grid.cols-3{grid-template-columns:repeat(3,minmax(0,1fr))}}
    .card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:18px;box-shadow:var(--shadow)}
    .muted{color:var(--muted)}
    .tag{display:inline-block;font-size:12px;padding:4px 8px;border:1px solid var(--border);border-radius:999px;color:var(--muted)}
    .form-grid{display:grid;gap:14px}
    @media(min-width:880px){.form-grid{grid-template-columns:1fr 1fr}}
    label{font-weight:600}
    input,select,textarea{width:100%;padding:12px 12px;border-radius:12px;border:1px solid var(--border);background:var(--bg-alt);color:var(--text)}
    textarea{min-height:180px}
    .tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
    .tab{padding:8px 12px;border-radius:10px;border:1px solid var(--border);cursor:pointer;background:var(--bg-alt)}
