  <section class="hero">
    <div class="container">
      <span class="pill">Projekt · unabhängig · nicht amtlich</span>
      <h1>Teilaustritt aus der öffentlich‑rechtlichen Kirche – <span class="muted">katholisch bleiben.</span></h1>
      <p class="lead">Infos, Generator und Checklisten für den Teilaustritt aus der öffentlich‑rechtlichen Kirchenkörperschaft – bei fortbestehendem Bekenntnis zur römisch‑katholischen Kirche. <em>Verfahren kantonal verschieden.</em></p>
      <div class="cta-row no-print">
        <a class="btn" href="#generator">Generator starten</a>
        <a class="btn secondary" href="#how">Ablauf ansehen</a>
      </div>
    </div>
  </section>

  <section id="how">
    <div class="container">
      <h2>So gehen Sie vor</h2>
      <p class="lead">Vier Schritte – kantonale Lage prüfen, entscheiden, schreiben, nachfassen.</p>
      <div class="grid cols-3">
        <div class="card"><div class="tag">1</div><h3>Prüfen</h3><p>Kantonale Rechtslage, Zuständigkeiten und Fristen ermitteln. Zuständige <strong>röm.-kath. Kirchgemeinde</strong> notieren.</p></div>
        <div class="card"><div class="tag">2</div><h3>Entscheiden</h3><p>Nichtzugehörigkeit zur <em>öffentlich‑rechtlichen Körperschaft</em> bei fortbestehendem kirchlichem Bekenntnis.</p></div>
        <div class="card"><div class="tag">3</div><h3>Schreiben</h3><p>Schreiben an die <strong>Kirchgemeinde</strong> mit dem Generator erstellen. Per Einschreiben versenden.</p></div>
        <div class="card"><div class="tag">4</div><h3>Nachfassen</h3><p>Schriftliche Bestätigung verlangen. Steuerverfügungen prüfen.</p></div>
      </div>
      <div class="notice" role="note"><strong>Hinweis:</strong> Keine Rechtsberatung; Inhalte allgemein und kantonal zu verifizieren.</div>
    </div>
  </section>

  <section id="generator">
    <div class="container two-col">
      <div>
        <h2>Vorlagen‑Generator</h2>
        <p class="lead">Briefe: <strong>(A)</strong> an die <strong>röm.-kath. Kirchgemeinde (öffentlich‑rechtliche Körperschaft)</strong> und <strong>(B)</strong> optionale Mitteilung an die <strong>kantonale Kirchenverwaltung/Steueramt</strong>. Mit Auto‑Vorschlag via <strong>PLZ</strong>.</p>
        <div class="card">
          <div class="form-grid">
            <div>
              <label for="name">Voller Name</label>
              <input id="name" placeholder="Vor- und Nachname" autocomplete="name" />
            </div>
            <div>
              <label for="dob">Geburtsdatum <span class="muted">(optional)</span></label>
              <input id="dob" type="date" />
            </div>
            <div>
              <label for="address">Adresse</label>
              <input id="address" placeholder="Strasse Nr., PLZ Ort" autocomplete="street-address" />
            </div>
            <div>
              <label for="zip">PLZ</label>
              <input id="zip" inputmode="numeric" placeholder="z. B. 4051" />
            </div>
            <div>
              <label for="email">E‑Mail <span class="muted">(für Rückfragen)</span></label>
              <input id="email" type="email" placeholder="name@example.ch" autocomplete="email" />
            </div>
            <div>
              <label for="canton">Kanton</label>
              <select id="canton" aria-label="Kanton">
                <option value="">Bitte wählen …</option>
                <option>AI</option><option>AR</option><option>BE</option><option>BL</option><option>BS</option>
                <option>FR</option><option>GE</option><option>GL</option><option>GR</option><option>JU</option><option>LU</option>
                <option>NE</option><option>NW</option><option>OW</option><option>SG</option><option>SH</option><option>SZ</option>
                <option>SO</option><option>TG</option><option>TI</option><option>UR</option><option>VD</option><option>VS</option>
                <option>ZG</option><option>ZH</option>
              </select>
            </div>
            <div>
              <label for="parish">Römisch‑katholische Kirchgemeinde</label>
              <input id="parish" placeholder="Name der Kirchgemeinde, Ort" />
            </div>
            <div>
              <label for="place">Ort</label>
              <input id="place" placeholder="z. B. Basel" />
            </div>
            <div>
              <label for="date">Datum</label>
              <input id="date" type="date" />
            </div>
          </div>
        </div>

        <div class="card">
          <div class="tabs" role="tablist" aria-label="Vorlagentyp">
            <button class="tab" role="tab" id="tabA" aria-selected="true" aria-controls="panelA">(A) Kirchgemeinde</button>
            <button class="tab" role="tab" id="tabB" aria-selected="false" aria-controls="panelB">(B) Verwaltung/Steueramt</button>
          </div>

          <div id="panelA" role="tabpanel" aria-labelledby="tabA">
            <div class="actions no-print">
              <button class="btn" id="btn-generate-a">Text erstellen</button>
              <button class="btn secondary" id="btn-copy-a" title="In die Zwischenablage kopieren">Kopieren</button>
              <button class="btn ghost" id="btn-doc-a" title="Als .doc herunterladen">Als .doc herunterladen</button>
              <button class="btn ghost" onclick="window.print()" title="Diesen Brief drucken">Drucken</button>
            </div>
            <div id="previewA" class="preview" aria-live="polite" aria-label="Vorschau Schreiben A"></div>
          </div>

          <div id="panelB" role="tabpanel" aria-labelledby="tabB" hidden>
            <div class="actions no-print">
              <button class="btn" id="btn-generate-b">Text erstellen</button>
              <button class="btn secondary" id="btn-copy-b" title="In die Zwischenablage kopieren">Kopieren</button>
              <button class="btn ghost" id="btn-doc-b" title="Als .doc herunterladen">Als .doc herunterladen</button>
              <button class="btn ghost" onclick="window.print()" title="Diesen Brief drucken">Drucken</button>
            </div>
            <div id="previewB" class="preview" aria-live="polite" aria-label="Vorschau Schreiben B"></div>
          </div>

          <p class="muted" style="margin-top:10px">Tipp: Senden Sie die Schreiben per <strong>Einschreiben</strong>. Legen Sie bei Bedarf Kopien (ID, Taufbestätigung) bei.</p>
        </div>
      </div>

      <aside>
        <div class="card">
          <h3>Kantonale Hinweise (allgemein)</h3>
          <p class="muted">Zuständigkeiten unterscheiden sich. Prüfen Sie die Webseiten der kantonalen Kirchenverwaltung und der Kirchgemeinde. Allgemeine Tipps:</p>
          <ul>
            <li><strong>Klar</strong> formulieren: Nichtzugehörigkeit zur <em>öffentlich‑rechtlichen Kirchenkörperschaft</em>, aber fortbestehende Zugehörigkeit zur römisch‑katholischen Kirche.</li>
            <li><strong>Bestätigung</strong> innert Frist (z. B. 30 Tage) verlangen.</li>
            <li><strong>Belege</strong> (Einwurf, Rückschein, Antwort) aufbewahren.</li>
            <li><strong>Steuerveranlagung</strong> prüfen.</li>
          </ul>
          <div class="notice danger" role="note"><strong>Wichtig:</strong> Teilaustritt ist kantonal unterschiedlich geregelt. Im Zweifel Rechtsauskunft einholen.</div>
        </div>

        <div class="card">
          <h3>Kirchgemeinde‑Verzeichnis</h3>
          <p class="muted">Geben Sie Ihre <strong>PLZ</strong> ein. Der Generator schlägt – sofern im Verzeichnis vorhanden – die zugehörige Kirchgemeinde vor und füllt Felder automatisch. <em>Kanton Aargau (AG) ist ausgeschlossen.</em></p>
          <div class="form-grid">
            <div>
              <label for="zipSearch">PLZ suchen</label>
              <input id="zipSearch" inputmode="numeric" placeholder="z. B. 4051" />
            </div>
          </div>
          <div id="zipResults" class="muted" style="margin-top:10px"></div>
        </div>

        <div class="card">
          <h3>Kanton wählen</h3>
          <div class="canton-board" id="cantonBoard"></div>
          <div id="cantonNote" class="muted" style="margin-top:12px"></div>
        </div>
      </aside>
    </div>
  </section>

  <section id="cantons">
    <div class="container">
      <h2>Schweizer Kantone</h2>
      <p class="lead">Klicken Sie auf Ihren Kanton, um Hinweise einzublenden. Nutzen Sie den Generator, um die Adressaten zu personalisieren.</p>
      <div class="grid cols-3" id="cantonCards"></div>
    </div>
  </section>

  <section id="faq">
    <div class="container">
      <h2>FAQ</h2>
      <div class="grid cols-3">
        <details class="card"><summary><strong>Was bedeutet „Teilaustritt“?</strong></summary>
          <p>Nichtzugehörigkeit zur öffentlich‑rechtlichen Kirchenkörperschaft (keine Kirchensteuer), bei fortbestehender Zugehörigkeit zur römisch‑katholischen Kirche als Glaubensgemeinschaft. Praxis kantonal verschieden.</p>
        </details>
        <details class="card"><summary><strong>Bin ich danach noch katholisch?</strong></summary>
          <p>Die Frage berührt kirchliches (kanonisches) und staatliches Recht. Ziel ist, das Bekenntnis nicht zu berühren; klären Sie dies im Zweifel mit Ihrer Kirchgemeinde.</p>
        </details>
        <details class="card"><summary><strong>Zahle ich weiterhin Kirchensteuer?</strong></summary>
          <p>Kirchensteuerpflicht ist kantonal geregelt. Prüfen Sie Ihre Veranlagung und lassen Sie Korrekturen bestätigen.</p>
        </details>
        <details class="card"><summary><strong>Gibt es Fristen?</strong></summary>
          <p>Teilweise Stichtage (z. B. Steuerperiode). Zuständige Stelle anfragen, schriftliche Auskunft verlangen.</p>
        </details>
        <details class="card"><summary><strong>Welche Nachweise brauche ich?</strong></summary>
          <p>Üblich sind Identitätsnachweis und Adresse. Mancherorts ist eine Taufbestätigung hilfreich.</p>
        </details>
        <details class="card"><summary><strong>Brauche ich einen Anwalt?</strong></summary>
          <p>Nicht zwingend. Bei unklarer Rechtslage, ausbleibender Reaktion oder Ablehnung kann Beratung sinnvoll sein.</p>
        </details>
      </div>
    </div>
  </section>

  <section id="contact">
    <div class="container">
      <h2>Kontakt</h2>
      <div class="two-col">
        <form class="card" onsubmit="contactSubmit(event)">
          <div class="form-grid">
            <div>
              <label for="cName">Ihr Name</label>
              <input id="cName" required placeholder="Name" />
            </div>
            <div>
              <label for="cMail">Ihre E‑Mail</label>
              <input id="cMail" type="email" required placeholder="name@example.ch" />
            </div>
            <div style="grid-column:1/-1">
              <label for="cMsg">Nachricht</label>
              <textarea id="cMsg" required placeholder="Ihr Anliegen…"></textarea>
            </div>
          </div>
          <label style="display:flex;gap:10px;align-items:center;margin:10px 0">
            <input type="checkbox" id="cConsent" required />
            <span class="muted">Ich bin einverstanden, dass meine Angaben zur Beantwortung meiner Anfrage verarbeitet werden.</span>
          </label>
          <button class="btn">Nachricht senden</button>
          <p id="cStatus" class="muted" aria-live="polite"></p>
        </form>
        <div class="card legal">
          <h3>Impressum & Datenschutz</h3>
          <small>Verantwortlich: <em>Teilaustritt.ch (Projektinitiative)</em> · Schweiz</small>
          <small>Haftungsausschluss: Keine Rechtsberatung. Alle Angaben ohne Gewähr. Prüfen Sie kantonale Bestimmungen.</small>
          <small>Datenschutz: Es werden keine Cookies gesetzt. Formulardaten werden nur zur Beantwortung Ihrer Anfrage verwendet.</small>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container" style="display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap">
      <div>© <span id="year"></span> Teilaustritt.ch</div>
      <div class="muted">Version 0.3 · Entwurf mit Kirchgemeinde‑Verzeichnis (AG ausgeschlossen)</div>
    </div>
  </footer>

  <script>
    const $ = (sel, root=document) => root.querySelector(sel);
    const $$ = (sel, root=document) => [...root.querySelectorAll(sel)];

    // Nav active link
    const links = $$('.nav-link');
    const sections = links.map(a => $(a.getAttribute('href'))).filter(Boolean);
    document.addEventListener('scroll', () => {
      const y = window.scrollY + 120;
      for (const [i,sec] of sections.entries()){
        const next = sections[i+1];
        if (y >= sec.offsetTop && (!next || y < next.offsetTop)){
          links.forEach(l=>l.classList.remove('active'));
          links[i].classList.add('active');
          break;
        }
      }
    }, {passive:true});

    // Year
    $('#year').textContent = new Date().getFullYear();

    // Tabs
    const tabA = $('#tabA'), tabB=$('#tabB');
    const panelA = $('#panelA'), panelB = $('#panelB');
    function selectTab(which){ if(which==='A'){ tabA.setAttribute('aria-selected','true'); tabB.setAttribute('aria-selected','false'); panelA.hidden=false; panelB.hidden=true;} else { tabA.setAttribute('aria-selected','false'); tabB.setAttribute('aria-selected','true'); panelA.hidden=true; panelB.hidden=false; } }
    tabA?.addEventListener('click',()=>selectTab('A'));
    tabB?.addEventListener('click',()=>selectTab('B'));

    // Cantons + notes (AG bewusst ausgelassen)
    const CANTONS = ['AI','AR','BE','BL','BS','FR','GE','GL','GR','JU','LU','NE','NW','OW','SG','SH','SZ','SO','TG','TI','UR','VD','VS','ZG','ZH'];
    const notes = Object.fromEntries(CANTONS.map(k=>[k,`Hinweis zu ${k}: Verfahren und Zuständigkeit kantonal reglementiert. Erfragen Sie schriftlich Zuständigkeit (Kirchenverwaltung/Kirchgemeinde), allfällige Fristen/Stichtage und Bestätigung des Status.`]));

    // === Röm.-kath. Kirchgemeinden (Auszug, AG ausgeschlossen). Mehr Einträge leicht ergänzbar. ===
    // Struktur: { plz: '4051', canton: 'BS', kirchgemeinde: 'Röm.-kath. Kirchgemeinde St. Peter und Paul Basel', ort: 'Basel' }
    const PARISH_DB = [
      // Basel‑Stadt (BS)
      {plz:'4001',canton:'BS',kirchgemeinde:'Röm.-kath. Kirchgemeinde St. Marien Basel',ort:'Basel'},
      {plz:'4051',canton:'BS',kirchgemeinde:'Röm.-kath. Kirchgemeinde St. Peter und Paul Basel',ort:'Basel'},
      {plz:'4052',canton:'BS',kirchgemeinde:'Röm.-kath. Kirchgemeinde St. Antonius Basel',ort:'Basel'},
      {plz:'4053',canton:'BS',kirchgemeinde:'Röm.-kath. Kirchgemeinde Dreifaltigkeit Basel',ort:'Basel'},
      {plz:'4055',canton:'BS',kirchgemeinde:'Röm.-kath. Kirchgemeinde St. Theresia Basel',ort:'Basel'},
      {plz:'4056',canton:'BS',kirchgemeinde:'Röm.-kath. Kirchgemeinde St. Joseph Basel',ort:'Basel'},
      {plz:'4057',canton:'BS',kirchgemeinde:'Röm.-kath. Kirchgemeinde Heiliggeist Basel',ort:'Basel'},
      // Basel‑Landschaft (BL)
      {plz:'4102',canton:'BL',kirchgemeinde:'Röm.-kath. Kirchgemeinde Reinach BL',ort:'Reinach'},
      {plz:'4132',canton:'BL',kirchgemeinde:'Röm.-kath. Kirchgemeinde Muttenz',ort:'Muttenz'},
      {plz:'4142',canton:'BL',kirchgemeinde:'Röm.-kath. Kirchgemeinde Münchenstein',ort:'Münchenstein'},
      {plz:'4410',canton:'BL',kirchgemeinde:'Röm.-kath. Kirchgemeinde Liestal',ort:'Liestal'},
      // Zürich (ZH)
