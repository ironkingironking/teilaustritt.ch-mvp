    .two-col{display:grid;gap:16px}
    @media(min-width:980px){.two-col{grid-template-columns:1.1fr .9fr}}
    .notice{background:color-mix(in srgb, var(--accent) 14%, transparent);border-left:3px solid var(--accent);padding:12px;border-radius:12px}
    .danger{background:color-mix(in srgb, var(--danger) 14%, transparent);border-left:3px solid var(--danger)}
