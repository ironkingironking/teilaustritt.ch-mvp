    function renderCantonBoard(){
      const board = $('#cantonBoard');
      board.innerHTML = '';
      CANTONS.forEach(k=>{
        const div = document.createElement('button');
        div.type='button';
        div.className='canton-card';
        div.innerHTML = `<strong>${k}</strong><div class="muted">Allgemeiner Hinweis</div>`;
        div.addEventListener('click',()=>{
          $('#canton').value = k;
          $('#cantonNote').textContent = notes[k];
          window.location.hash = '#generator';
        });
        board.appendChild(div);
      });
    }
    function renderCantonCards(){
      const wrap = $('#cantonCards');
      wrap.innerHTML = '';
      CANTONS.forEach(k=>{
        const card = document.createElement('div');
        card.className='card';
        card.innerHTML = `<div class="tag">Kanton</div><h3>${k}</h3><p class="muted">${notes[k]}</p><button class="btn ghost no-print">Im Generator verwenden</button>`;
        card.querySelector('button').addEventListener('click',()=>{ $('#canton').value = k; window.location.hash = '#generator'; });
        wrap.appendChild(card);
      });
    }

    function val(id){ return (document.getElementById(id).value || '').trim(); }
    function formatDate(v){ if(!v) return ''; try{ const d=new Date(v); return d.toLocaleDateString('de-CH',{year:'numeric',month:'long',day:'numeric'});}catch{return v;} }
    function buildHeader(){ const name=val('name'); const addr=val('address'); const email=val('email'); return `${name}\n${addr}\n${email?('E‑Mail: '+email+'\n'):''}`; }
    function buildPlaceDate(){ const place=val('place'); const date=formatDate(val('date'))||new Date().toLocaleDateString('de-CH'); return `${place}, ${date}`.trim().replace(/^,\s*/, ''); }

    function buildLetterA(){
      const name=val('name'); const dob=val('dob'); const addr=val('address'); const canton=val('canton'); const parish=val('parish'); const pd=buildPlaceDate(); const header=buildHeader();
      return `${header}\n\nAn die römisch‑katholische Kirchgemeinde\n${parish||'[Kirchgemeinde]'}${canton?` (${canton})`:''}\n\nBetreff: Gesuch um Nichtzugehörigkeit zur öffentlich‑rechtlichen Kirchenkörperschaft unter Wahrung der Zugehörigkeit zur römisch‑katholischen Kirche\n\nSehr geehrte Damen und Herren\n\nIch, ${name}${dob?` (geb. ${new Date(dob).toLocaleDateString('de-CH')})`:''}, wohnhaft in ${addr}, ersuche höflich um Feststellung/Eintragung, dass ich der öffentlich‑rechtlichen Kirchenkörperschaft (${parish||'Ihre Kirchgemeinde'}) des Kantons ${canton||'…'} nicht angehöre und somit keine Kirchensteuerpflicht aus dieser Zugehörigkeit besteht.\n\nGleichzeitig halte ich fest, dass meine Zugehörigkeit zur römisch‑katholischen Kirche als Glaubensgemeinschaft unberührt bleibt. Dieses Gesuch betrifft ausschliesslich die öffentlich‑rechtliche Mitgliedschaft/Zurechnung.\n\nIch ersuche um eine schriftliche Bestätigung innert 30 Tagen. Sofern ergänzende Angaben oder eine andere zuständige Stelle erforderlich sind, bitte ich um entsprechende Mitteilung.\n\nMit freundlichen Grüssen\n\n${name}\n\n${pd}`;
    }
    function buildLetterB(){
      const name=val('name'); const dob=val('dob'); const addr=val('address'); const canton=val('canton'); const parish=val('parish'); const pd=buildPlaceDate(); const header=buildHeader();
      return `${header}\n\nAn die kantonale Kirchenverwaltung / Steueramt\n(${canton||'Kanton …'})\n\nBetreff: Mitteilung – Nichtzugehörigkeit zur öffentlich‑rechtlichen Kirchgemeinde bei fortbestehender Zugehörigkeit zur römisch‑katholischen Kirche\n\nSehr geehrte Damen und Herren\n\nHiermit informiere ich Sie, dass ich bei der römisch‑katholischen Kirchgemeinde ${parish||''} (${canton||'…'}) beantragt habe (bzw. beantragen werde), nicht der öffentlich‑rechtlichen Kirchenkörperschaft zugerechnet zu werden.\n\nIch halte fest, dass meine Zugehörigkeit zur römisch‑katholischen Kirche als Glaubensgemeinschaft fortbesteht. Diese Mitteilung dient der Klarstellung; es handelt sich nicht um einen Austritt aus dem Glauben.\n\nFür eine kurze schriftliche Bestätigung des Eingangs dieser Mitteilung danke ich Ihnen.\n\nMit freundlichen Grüssen\n\n${name}${dob?`\n(geb. ${new Date(dob).toLocaleDateString('de-CH')})`:''}\n${addr}\n\n${pd}`;
    }

    function updatePreview(which){ if(which==='A') $('#previewA').textContent=buildLetterA(); else $('#previewB').textContent=buildLetterB(); }
    function copyPreview(which){ const txt = which==='A'?$('#previewA').textContent:$('#previewB').textContent; if(!txt){alert('Bitte zuerst den Text erstellen.');return;} navigator.clipboard.writeText(txt).then(()=>alert('In die Zwischenablage kopiert.')); }
    function downloadDoc(which){ const title=which==='A'?'Teilaustritt_Kirchgemeinde':'Mitteilung_Verwaltung'; const body=(which==='A'?$('#previewA').textContent:$('#previewB').textContent)||''; if(!body){alert('Bitte zuerst den Text erstellen.');return;} const html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>${title}</title></head><body><pre style="font:12pt/1.4 -apple-system,Segoe UI,Roboto,Arial">${body.replace(/[&<>]/g,s=>({"&":"&amp;","<":"&lt;",">":"&gt;"}[s]))}</pre></body></html>`; const blob=new Blob([html],{type:'application/msword'}); const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download=title+'.doc'; a.click(); setTimeout(()=>URL.revokeObjectURL(url),1000);} 

    $('#btn-generate-a')?.addEventListener('click',()=>updatePreview('A'));
    $('#btn-generate-b')?.addEventListener('click',()=>updatePreview('B'));
    $('#btn-copy-a')?.addEventListener('click',()=>copyPreview('A'));
    $('#btn-copy-b')?.addEventListener('click',()=>copyPreview('B'));
    $('#btn-doc-a')?.addEventListener('click',()=>downloadDoc('A'));
    $('#btn-doc-b')?.addEventListener('click',()=>downloadDoc('B'));

    // Auto‑Vorschlag anhand PLZ (Generator‑Feld)
    function applyParishFromZip(zip){
      const z = (zip||'').trim();
      const hit = PARISH_DB.find(e=>e.plz===z);
      if(hit){
        if(!val('parish')) $('#parish').value = hit.kirchgemeinde;
        if(!val('canton')) $('#canton').value = hit.canton;
        if(!val('place')) $('#place').value = hit.ort;
        const note = notes[hit.canton]; if(note) $('#cantonNote').textContent = note;
      }
    }
    $('#zip').addEventListener('input', e=>applyParishFromZip(e.target.value));

    // Verzeichnis‑Suche (Seitenleiste)
    function renderZipResults(z){
      const box = $('#zipResults');
      box.innerHTML = '';
      if(!z){ box.textContent='Bitte PLZ eingeben.'; return; }
      const hit = PARISH_DB.find(e=>e.plz===z.trim());
      if(!hit){ box.textContent='Keine Einträge gefunden (AG ausgeschlossen / Demo‑Bestand).'; return; }
      const div = document.createElement('div');
      div.innerHTML = `<strong>${z}</strong>: ${hit.kirchgemeinde} (${hit.canton})<br><small>${hit.ort||''}</small><br>`;
      const btn = document.createElement('button');
      btn.className='btn ghost no-print';
      btn.textContent='In den Generator übernehmen';
      btn.addEventListener('click', ()=>{ $('#zip').value=z; $('#parish').value=hit.kirchgemeinde; $('#canton').value=hit.canton; if(hit.ort) $('#place').value=hit.ort; window.location.hash='#generator'; });
      div.appendChild(btn);
      box.appendChild(div);
    }
    $('#zipSearch').addEventListener('input', e=>renderZipResults(e.target.value));

    // Persist simple state
    const fields = ['name','dob','address','zip','email','canton','parish','place','date'];
    fields.forEach(id=>{ const el=document.getElementById(id); if(!el) return; const saved=localStorage.getItem('ta_'+id); if(saved) el.value=saved; el.addEventListener('change',()=>localStorage.setItem('ta_'+id, el.value)); });

    // Contact form -> mailto
    function contactSubmit(e){ e.preventDefault(); const name=val('cName'); const mail=val('cMail'); const msg=val('cMsg'); if(!$('#cConsent').checked){ $('#cStatus').textContent='Bitte Zustimmung zum Datenschutz erteilen.'; return; } const subject=encodeURIComponent('Anfrage Teilaustritt.ch'); const body=encodeURIComponent(`Name: ${name}\nE‑Mail: ${mail}\n\nNachricht:\n${msg}`); window.location.href=`mailto:kontakt@teilaustritt.ch?subject=${subject}&body=${body}`; $('#cStatus').textContent='Ihr Mailprogramm sollte sich öffnen. Vielen Dank!'; }
    window.contactSubmit = contactSubmit;

    // Render widgets
    renderCantonBoard();
    renderCantonCards();

    // Init previews
    updatePreview('A');
    updatePreview('B');
  </script>
</body>
</html>
